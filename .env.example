# WDK Wallet Seed (BIP-39, 12 or 24 words)
WDK_SEED="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"

# Arbitrum One RPC (default: public endpoint — replace with Alchemy/Infura for production)
ARB_RPC_URL=https://arb1.arbitrum.io/rpc

# Creator wallet address (Arbitrum — receives USDT tips)
CREATOR_ADDRESS=0x0000000000000000000000000000000000000000

# Demo config
FAN_DEPOSIT_AMOUNT=100
TIP_AMOUNT=10
MILESTONE_TRIGGER=1000_viewers

# Server port
PORT=3001

# Optional: Groq API key for LLM sentiment scoring
# GROQ_API_KEY=gsk_...
